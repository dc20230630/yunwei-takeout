.login-scroll-view {
  width: 100%;
  height: 100%;
  background-color: #ffffff;
}

.login-wrap {
  padding: 80rpx 48rpx;
  display: flex;
  flex-direction: column;
}

/* Logo 样式 */
.login-logo-wrap {
  display: flex;
  margin-bottom: 48rpx;
}

.login-logo-img {
  width: 128rpx;
  height: 128rpx;
  border-radius: 36rpx;
  box-shadow: 0 10rpx 24rpx rgba(36, 107, 255, 0.15);
}

.login-title {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--gray-900);
  margin-bottom: 16rpx;
}

.login-subtitle {
  font-size: 26rpx;
  color: var(--gray-500);
  margin-bottom: 72rpx;
}

/* 输入表单 */
.form-group {
  margin-bottom: 56rpx;
}

.input-row {
  border-bottom: 1rpx solid var(--gray-200);
  padding: 16rpx 0;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.login-input {
  flex: 1;
  height: 80rpx;
  background-color: transparent;
  font-size: 34rpx;
  outline: none;
}

.code-row {
  display: flex;
  align-items: center;
}

.code-btn {
  font-size: 26rpx;
  color: var(--orange);
  padding-left: 28rpx;
  border-left: 1rpx solid var(--gray-200);
  background-color: transparent;
  border-radius: 0;
  line-height: 1.5;
  margin: 0;
}

.code-btn::after {
  border: none;
}

.code-btn[disabled] {
  color: var(--gray-400);
  background-color: transparent !important;
}

.submit-btn {
  width: 100% !important;
  font-size: 34rpx;
  padding: 28rpx 0;
  margin-bottom: 36rpx;
}

/* 协议选择 */
.agreement-label {
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
  font-size: 22rpx;
  color: var(--gray-400);
  line-height: 1.6;
  margin-top: 10rpx;
}

.agree-checkbox {
  transform: scale(0.7);
  margin-top: -4rpx;
}

.agreement-text {
  flex: 1;
}

.orange-link {
  color: var(--orange);
  font-weight: bold;
}

.other-login-wrap {
  margin-top: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.split-line-wrap {
  display: flex;
  align-items: center;
  width: 100%;
  margin-bottom: 40rpx;
}

.split-line {
  height: 1rpx;
  background-color: var(--gray-200);
  flex: 1;
}

.split-text {
  font-size: 22rpx;
  color: var(--gray-400);
  padding: 0 24rpx;
}

.wechat-login-btn-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: #e9f9ee;
  display: grid;
  place-items: center;
}

.wechat-icon {
  font-size: 50rpx;
}
