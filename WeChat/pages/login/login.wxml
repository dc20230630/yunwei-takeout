<!-- pages/login/login.wxml -->
<!-- 自定义顶部栏带返回 -->
<view class="custom-navbar" style="padding-top: {{statusBarHeight}}px; height: {{navBarHeight}}px;">
  <view class="custom-navbar-back" bindtap="goBack">
    <view class="custom-navbar-back-icon"></view>
  </view>
  <view class="custom-navbar-title">登录</view>
</view>
<view style="height: {{totalNavHeight}}px;"></view>

<scroll-view scroll-y class="login-scroll-view" style="height: calc(100vh - {{totalNavHeight}}px);">
  <view class="login-wrap">
    <!-- 标志 Logo -->
    <view class="login-logo-wrap">
      <image class="login-logo-img" src="/assets/logo.png" mode="aspectFit" />
    </view>
    
    <view class="login-title">欢迎登录云味外卖</view>
    <view class="login-subtitle">未注册的手机号验证后将自动创建账号</view>

    <!-- 表单输入 -->
    <view class="form-group">
      <view class="input-row">
        <input 
          type="number" 
          maxlength="11" 
          placeholder="请输入手机号码" 
          value="{{phone}}"
          bindinput="onPhoneInput"
          class="login-input"
        />
      </view>
      
      <view class="input-row code-row">
        <input 
          type="number" 
          maxlength="6" 
          placeholder="请输入验证码" 
          value="{{code}}"
          bindinput="onCodeInput"
          class="login-input"
        />
        <button 
          class="code-btn" 
          disabled="{{countdown > 0}}" 
          bindtap="getSMSCode"
        >
          {{countdown > 0 ? countdown + 's后获取' : '获取验证码'}}
        </button>
      </view>
    </view>

    <!-- 登录按钮 -->
    <button class="primary-btn submit-btn" bindtap="login">登录</button>

    <!-- 用户协议协议确认 -->
    <label class="agreement-label" bindtap="toggleAgree">
      <checkbox class="agree-checkbox" checked="{{agree}}" color="#ff6b21"></checkbox>
      <view class="agreement-text">
        登录即代表同意 <text class="orange-link" catchtap="showUserAgreement">《用户协议》</text> 和 <text class="orange-link" catchtap="showPrivacyPolicy">《隐私政策》</text>
      </view>
    </label>

    <!-- 微信登录 -->
    <view class="other-login-wrap">
      <view class="split-line-wrap">
        <view class="split-line"></view>
        <text class="split-text">其他方式登录</text>
        <view class="split-line"></view>
      </view>
      <view class="wechat-login-btn-wrap" bindtap="wechatLogin">
        <view class="wechat-icon">💬</view>
      </view>
    </view>
  </view>
</scroll-view>
