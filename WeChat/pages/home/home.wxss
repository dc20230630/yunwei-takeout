/* pages/home/home.wxss */
.home-scroll-container {
  height: calc(100vh - 100rpx);
  background-color: var(--gray-50);
}

/* 顶部定位栏 */
.location-bar {
  display: flex;
  align-items: center;
  margin-left: 20rpx;
  height: 60rpx;
}

.location-icon-wrap {
  margin-right: 8rpx;
  display: flex;
  align-items: center;
}

.pin-icon {
  width: 32rpx;
  height: 32rpx;
  background-color: var(--orange);
  clip-path: polygon(50% 0%, 85% 30%, 50% 100%, 15% 30%);
}

.location-text {
  font-size: 30rpx;
  font-weight: bold;
  max-width: 300rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: var(--gray-900);
}

.arrow-down-icon {
  width: 0;
  height: 0;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-top: 10rpx solid var(--gray-800);
  margin-left: 10rpx;
}

/* 搜索框 */
.search-box-wrap {
  padding: 20rpx 30rpx;
  background-color: #ffffff;
}

.search-box {
  height: 80rpx;
  border-radius: 999rpx;
  background-color: var(--gray-100);
  display: flex;
  align-items: center;
  padding: 0 10rpx 0 30rpx;
  color: var(--gray-400);
  font-size: 26rpx;
}

.search-icon {
  margin-right: 14rpx;
}

.search-box text {
  flex: 1;
}

.search-btn {
  background-color: var(--orange);
  color: #ffffff;
  border-radius: 999rpx;
  padding: 12rpx 32rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.home-content {
  padding: 30rpx 30rpx 120rpx;
}

/* 横幅 Banner */
.banner {
  min-height: 240rpx;
  border-radius: 36rpx;
  padding: 40rpx;
  color: #ffffff;
  background: linear-gradient(120deg, #ff8a3d, #f24444);
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 12rpx 24rpx rgba(255, 107, 33, 0.18);
  margin-bottom: 40rpx;
}

.banner::after {
  content: "";
  position: absolute;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.11);
  right: -60rpx;
  top: -80rpx;
  z-index: 1;
}

.banner-left {
  position: relative;
  z-index: 2;
}

.banner-title {
  font-size: 44rpx;
  font-weight: bold;
  font-style: italic;
  margin-bottom: 12rpx;
}

.banner-subtitle {
  font-size: 26rpx;
  color: #ffe3d4;
  margin-bottom: 24rpx;
}

.banner-btn {
  background-color: #ffffff;
  color: var(--orange);
  border-radius: 999rpx;
  padding: 12rpx 32rpx;
  font-size: 24rpx;
  font-weight: bold;
  display: inline-block;
}

.banner-food {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.2);
  display: grid;
  place-items: center;
  font-size: 80rpx;
  position: relative;
  z-index: 2;
  margin-right: 10rpx;
}

/* 分类金刚区 */
.category-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 30rpx 14rpx;
  margin-bottom: 40rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
  color: var(--gray-600);
}

.category-icon {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  display: grid;
  place-items: center;
  font-size: 44rpx;
}

/* 段落区块 */
.section {
  margin-top: 40rpx;
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title-main {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--gray-900);
}

.section-title-main-wrap {
  display: flex;
  align-items: center;
}

.fire-icon {
  margin-right: 10rpx;
  font-size: 34rpx;
}

.section-title-more {
  font-size: 24rpx;
  color: var(--gray-500);
  display: flex;
  align-items: center;
}

.arrow-right {
  width: 12rpx;
  height: 12rpx;
  border-top: 3rpx solid var(--gray-400);
  border-right: 3rpx solid var(--gray-400);
  transform: rotate(45deg);
  margin-left: 6rpx;
}

/* 今日推荐横向滑动 */
.recommend-scroll {
  display: flex;
  white-space: nowrap;
  width: 100%;
  padding-bottom: 10rpx;
}

.recommend-card {
  display: inline-block;
  width: 320rpx;
  background-color: #ffffff;
  border: 1rpx solid #f0f1f3;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
  margin-right: 24rpx;
  vertical-align: top;
}

.recommend-img {
  width: 100%;
  height: 200rpx;
  background-color: var(--gray-100);
}

.recommend-info {
  padding: 20rpx;
}

.recommend-name {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--gray-900);
  margin-bottom: 6rpx;
}

.recommend-desc {
  font-size: 22rpx;
  color: var(--gray-400);
  margin-bottom: 16rpx;
}

.recommend-foot {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.recommend-price {
  color: var(--orange);
  font-weight: bold;
  font-size: 34rpx;
}

.recommend-price::before {
  content: "¥";
  font-size: 22rpx;
  margin-right: 2rpx;
}

.plus-btn {
  width: 52rpx;
  height: 52rpx;
  background-color: var(--orange);
  color: #ffffff;
  border-radius: 50%;
  display: grid;
  place-items: center;
  font-size: 34rpx;
  font-weight: bold;
}

/* 热销榜单 */
.sales-card {
  padding: 30rpx;
}

.sales-item {
  display: flex;
  gap: 24rpx;
  position: relative;
  margin-bottom: 30rpx;
}

.sales-item:last-child {
  margin-bottom: 0;
}

.sales-img {
  width: 150rpx;
  height: 150rpx;
  border-radius: 24rpx;
  background-color: var(--gray-100);
}

.rank-badge {
  position: absolute;
  left: 0;
  top: 0;
  width: 44rpx;
  height: 44rpx;
  color: #ffffff;
  border-radius: 20rpx 0 20rpx 0;
  display: grid;
  place-items: center;
  font-size: 22rpx;
  font-weight: bold;
  z-index: 5;
}

.rank-badge.r1 { background-color: #ef4444; }
.rank-badge.r2 { background-color: #fb923c; }
.rank-badge.r3 { background-color: #fbbf24; }

.sales-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 4rpx 0;
}

.sales-name {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--gray-900);
}

.sales-meta {
  font-size: 22rpx;
  color: var(--gray-500);
}

.sales-price {
  color: var(--orange);
  font-weight: bold;
  font-size: 32rpx;
}

.sales-price::before {
  content: "¥";
  font-size: 22rpx;
}
