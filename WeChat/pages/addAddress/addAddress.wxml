<!-- pages/addAddress/addAddress.wxml -->
<!-- 自定义顶部栏带返回 -->
<view class="custom-navbar" style="padding-top: {{statusBarHeight}}px; height: {{navBarHeight}}px;">
  <view class="custom-navbar-back" bindtap="goBack">
    <view class="custom-navbar-back-icon"></view>
  </view>
  <view class="custom-navbar-title">{{isEditMode ? '编辑收货地址' : '新建收货地址'}}</view>
</view>
<view style="height: {{totalNavHeight}}px;"></view>

<view class="form-container">
  <view class="form-card card">
    <!-- 联系人 -->
    <view class="form-row">
      <text class="row-label">联系人</text>
      <input 
        type="text" 
        placeholder="请填写收货人姓名" 
        value="{{name}}" 
        bindinput="onNameInput"
        class="row-input"
      />
    </view>

    <!-- 性别单选 -->
    <view class="form-row sex-row">
      <text class="row-label"></text>
      <view class="sex-options">
        <view 
          class="sex-option {{gender === '先生' ? 'active' : ''}}" 
          bindtap="selectGender" 
          data-val="先生"
        >
          先生
        </view>
        <view 
          class="sex-option {{gender === '女士' ? 'active' : ''}}" 
          bindtap="selectGender" 
          data-val="女士"
        >
          女士
        </view>
      </view>
    </view>

    <!-- 手机号 -->
    <view class="form-row">
      <text class="row-label">手机号</text>
      <input 
        type="number" 
        maxlength="11" 
        placeholder="请填写收货人手机号" 
        value="{{phone}}" 
        bindinput="onPhoneInput"
        class="row-input"
      />
    </view>

    <!-- 省市区定位 (使用微信原生省市区选择器) -->
    <view class="form-row">
      <text class="row-label">收货地址</text>
      <picker 
        mode="region" 
        bindchange="onRegionChange" 
        value="{{regionArray}}"
        class="row-picker-wrap"
      >
        <view class="picker-val {{region ? '' : 'placeholder'}}">
          {{region || '点击选择省/市/区'}}
        </view>
      </picker>
      <view class="arrow-right"></view>
    </view>

    <!-- 门牌号详细地址 -->
    <view class="form-row">
      <text class="row-label">门牌号</text>
      <input 
        type="text" 
        placeholder="详细地址，例：16号楼5层501室" 
        value="{{detail}}" 
        bindinput="onDetailInput"
        class="row-input"
      />
    </view>

    <!-- 标签选择 -->
    <view class="form-row label-row">
      <text class="row-label">标签</text>
      <view class="tag-options">
        <view 
          class="tag-option {{tag === item ? 'active' : ''}}" 
          wx:for="{{tagOptions}}" 
          wx:key="*this"
          bindtap="selectTag" 
          data-val="{{item}}"
        >
          {{item}}
        </view>
      </view>
    </view>

    <!-- 默认地址开关 -->
    <view class="form-row default-row">
      <text class="row-label">设为默认</text>
      <switch 
        checked="{{isDefault}}" 
        color="#ff6b21" 
        bindchange="onDefaultChange"
        class="default-switch"
      />
    </view>
  </view>

  <!-- 提交与删除操作区 -->
  <view class="submit-wrap">
    <button class="primary-btn save-btn" bindtap="saveAddress">保存地址</button>
    <button 
      class="plain-btn delete-btn" 
      wx:if="{{isEditMode}}" 
      bindtap="deleteAddress"
    >
      删除该地址
    </button>
  </view>
</view>
