/* pages/review/review.wxss */
.review-container {
  min-height: calc(100vh - 100rpx);
  background-color: var(--gray-50);
  padding: 30rpx 24rpx;
}

.review-card {
  padding: 36rpx;
  margin-bottom: 24rpx;
}

/* 店铺打分 */
.review-shop-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.shop-logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 20rpx;
  background-color: var(--gray-100);
  margin-bottom: 16rpx;
}

.shop-name {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--gray-900);
  margin-bottom: 30rpx;
}

.stars-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.star-item {
  font-size: 72rpx;
  color: var(--gray-300);
}

.star-item.active {
  color: #fb923c;
}

.score-desc {
  font-size: 24rpx;
  color: var(--gray-500);
}

/* 文本评论区 */
.text-section {
  position: relative;
}

.review-textarea {
  width: 100%;
  height: 200rpx;
  font-size: 28rpx;
  line-height: 1.6;
  outline: none;
  background-color: transparent;
}

.text-counter {
  position: absolute;
  right: 30rpx;
  bottom: 20rpx;
  font-size: 20rpx;
  color: var(--gray-400);
}

/* 匿名区 */
.anonymous-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 36rpx;
}

.anonymous-label {
  font-size: 28rpx;
  color: var(--gray-700);
}

.anonymous-switch {
  transform: scale(0.9);
}

/* 提交 */
.submit-wrap {
  margin-top: 48rpx;
}

.submit-btn {
  width: 100% !important;
  font-size: 32rpx;
  padding: 24rpx 0;
}
