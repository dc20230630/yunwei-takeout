/* pages/orderList/orderList.wxss */
.order-container {
  height: calc(100vh - 100rpx);
  display: flex;
  flex-direction: column;
  background-color: var(--gray-50);
}

/* 顶部选项卡 */
.order-tabs-wrap {
  background-color: #ffffff;
  position: sticky;
  top: 0;
  z-index: 10;
  border-bottom: 1rpx solid var(--gray-200);
}

.order-tabs {
  display: flex;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 20rpx;
}

.order-tab {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: var(--gray-500);
  position: relative;
}

.order-tab.active {
  color: var(--gray-900);
  font-weight: bold;
}

.order-tab.active::after {
  content: "";
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background-color: var(--orange);
  border-radius: 6rpx 6rpx 0 0;
}

/* 滚动列表 */
.order-scroll-list {
  flex: 1;
  overflow: hidden;
}

.order-list-content {
  padding: 24rpx 24rpx 120rpx;
}

.order-card {
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.order-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid var(--gray-100);
  padding-bottom: 20rpx;
  margin-bottom: 24rpx;
}

.merchant-name {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--gray-900);
}

.order-status {
  font-size: 24rpx;
  color: var(--orange);
  font-weight: 500;
}

.order-status.cancelled {
  color: var(--gray-400);
}

/* 订单内容 */
.order-middle {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.order-pics {
  display: flex;
  gap: 16rpx;
  flex: 1;
  overflow-x: auto;
  white-space: nowrap;
}

.order-food-img {
  width: 112rpx;
  height: 112rpx;
  border-radius: 16rpx;
  background-color: var(--gray-100);
  display: inline-block;
}

.order-summary {
  text-align: right;
  padding-left: 30rpx;
}

.order-total-price {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--gray-900);
  margin-bottom: 6rpx;
}

.order-qty {
  font-size: 22rpx;
  color: var(--gray-400);
}

/* 订单底部操作 */
.order-foot {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-time {
  font-size: 22rpx;
  color: var(--gray-400);
}

.order-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  margin: 0;
  padding: 0 32rpx;
  height: 60rpx;
  line-height: 58rpx;
  font-size: 24rpx;
  border-radius: 999rpx;
  font-weight: 500;
  width: auto !important;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.action-btn::after {
  border: none;
}

.outline-small {
  border: 1rpx solid var(--gray-300);
  color: var(--gray-700);
  background-color: #ffffff;
}

.outline-small:active {
  background-color: var(--gray-100);
}

.orange-small {
  background-color: var(--orange-soft);
  color: var(--orange);
  border: 1rpx solid rgba(255, 107, 33, 0.2);
}

.solid-small {
  background-color: var(--orange);
  color: #ffffff;
}

.solid-small:active {
  background-color: var(--orange-dark);
}

/* 空列表状态 */
.empty-orders {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 26rpx;
  color: var(--gray-400);
  margin-bottom: 40rpx;
}

.empty-btn {
  font-size: 28rpx;
  padding: 18rpx 60rpx;
}
