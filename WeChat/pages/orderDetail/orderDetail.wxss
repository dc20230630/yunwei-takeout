/* pages/orderDetail/orderDetail.wxss */
.detail-container {
  height: calc(100vh - 100rpx);
  background-color: var(--gray-50);
}

.detail-scroll {
  height: 100%;
}

/* 地图区 */
.map-box-wrap {
  height: 380rpx;
  position: relative;
}

.map-box {
  width: 100%;
  height: 100%;
  background: linear-gradient(rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0.28)),
              url("https://images.unsplash.com/photo-1524661135-423995f22d0b?auto=format&fit=crop&w=900&q=80") center/cover;
  position: relative;
}

.map-tip {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  background-color: rgba(255, 255, 255, 0.94);
  padding: 26rpx 40rpx;
  border-radius: 26rpx;
  text-align: center;
  box-shadow: var(--shadow);
  width: 580rpx;
}

.map-tip-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--gray-900);
  margin-bottom: 8rpx;
}

.map-tip-desc {
  font-size: 22rpx;
  color: var(--gray-500);
}

.detail-content {
  padding: 0 24rpx 100rpx;
  position: relative;
  margin-top: -30rpx;
  z-index: 10;
}

/* 骑手卡片 */
.rider-card {
  padding: 24rpx;
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.rider-avatar {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  background-color: #dbeafe;
  display: grid;
  place-items: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.rider-info {
  flex: 1;
}

.rider-name {
  font-size: 26rpx;
  font-weight: bold;
  color: var(--gray-900);
  margin-bottom: 6rpx;
}

.rider-phone {
  font-size: 22rpx;
  color: var(--gray-400);
}

.call-rider-btn {
  margin: 0;
  padding: 0 24rpx;
  height: 56rpx;
  line-height: 54rpx;
  font-size: 22rpx;
  border-radius: 999rpx;
  background-color: transparent;
  color: var(--gray-700);
  border: 1rpx solid var(--gray-300);
  font-weight: bold;
}

.call-rider-btn::after {
  border: none;
}

/* 商品清单 */
.food-card {
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 26rpx;
  font-weight: bold;
  color: var(--gray-400);
  border-bottom: 1rpx solid var(--gray-100);
  padding-bottom: 16rpx;
  margin-bottom: 20rpx;
}

.food-item {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.food-item:last-child {
  margin-bottom: 0;
}

.food-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  background-color: var(--gray-100);
  margin-right: 20rpx;
}

.food-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 80rpx;
  padding: 2rpx 0;
}

.food-name {
  font-size: 26rpx;
  font-weight: bold;
  color: var(--gray-900);
}

.food-specs {
  font-size: 20rpx;
  color: var(--gray-400);
}

.food-qty {
  font-size: 22rpx;
  color: var(--gray-500);
}

.food-price-sub {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--gray-900);
}

/* 费用分割 */
.bill-breakdown {
  border-top: 1rpx dashed var(--gray-200);
  padding-top: 24rpx;
  margin-top: 24rpx;
}

.bill-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: var(--gray-500);
  margin-bottom: 16rpx;
}

.bill-line-val {
  color: var(--gray-900);
}

.coupon-line {
  color: var(--red);
}

.coupon-line .bill-line-val {
  color: var(--red);
  font-weight: bold;
}

.final-line {
  margin-top: 24rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--gray-100);
  margin-bottom: 0;
}

.final-label {
  font-size: 26rpx;
  font-weight: bold;
  color: var(--gray-900);
}

.final-val {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--orange);
}

/* 详情数据卡 */
.info-card {
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
}

.info-label {
  color: var(--gray-400);
  width: 140rpx;
}

.info-val {
  color: var(--gray-700);
  flex: 1;
  text-align: right;
  word-break: break-all;
}

.copy-wrap {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
}

.order-id-txt {
  font-family: monospace;
}

.copy-btn {
  margin: 0;
  padding: 0 16rpx;
  height: 38rpx;
  line-height: 36rpx;
  font-size: 20rpx;
  border-radius: 6rpx;
  background-color: var(--gray-100);
  color: var(--gray-600);
  border: 1rpx solid var(--gray-300);
}

.copy-btn::after {
  border: none;
}
