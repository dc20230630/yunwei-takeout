/**app.wxss**/
page {
  /* 云味主题配色 */
  --orange: #ff6b21;
  --orange-dark: #f25512;
  --orange-soft: #fff1e8;
  --red: #ef4444;
  --green: #22c55e;
  --blue: #3b82f6;
  --amber: #f59e0b;
  --pink: #ec4899;
  --purple: #8b5cf6;
  --gray-50: #f7f8fa;
  --gray-100: #f0f2f5;
  --gray-200: #e7e9ee;
  --gray-300: #d4d7dd;
  --gray-400: #9ca3af;
  --gray-500: #6b7280;
  --gray-600: #4b5563;
  --gray-700: #374151;
  --gray-800: #242a32;
  --gray-900: #171a20;
  --white: #fff;
  --shadow: 0 7rpx 24rpx rgba(23, 26, 32, .08);

  background-color: var(--gray-50);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
  color: var(--gray-900);
  font-size: 28rpx;
  box-sizing: border-box;
}

view, scroll-view, text, image, button, input, textarea {
  box-sizing: border-box;
}

/* 常用辅助工具类 */
.price {
  color: var(--orange);
  font-weight: bold;
}
.price::before {
  content: "¥";
  font-size: 22rpx;
  margin-right: 2rpx;
}

.muted {
  color: var(--gray-500);
}

.card {
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(23, 26, 32, .045);
}

.line-clamp-1 {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.line-clamp-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* 自定义顶部导航栏通用样式 */
.custom-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  z-index: 999;
  border-bottom: 1rpx solid var(--gray-200);
  display: flex;
  align-items: center;
  box-sizing: content-box !important;
}

.custom-navbar-back {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: absolute;
  left: 10rpx;
  z-index: 1000;
}

.custom-navbar-back-icon {
  width: 20rpx;
  height: 20rpx;
  border-left: 5rpx solid var(--gray-800);
  border-bottom: 5rpx solid var(--gray-800);
  transform: rotate(45deg);
}

.custom-navbar-title {
  width: 100%;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--gray-900);
}

/* 按钮通用样式 */
.primary-btn {
  background: var(--orange);
  color: #fff;
  border-radius: 999rpx;
  font-weight: 600;
  text-align: center;
  padding: 24rpx 44rpx;
  box-shadow: 0 8rpx 18rpx rgba(255, 107, 33, .2);
  border: none;
}

.primary-btn:active {
  background: var(--orange-dark);
}

.plain-btn {
  border: 1rpx solid var(--gray-300);
  border-radius: 999rpx;
  padding: 20rpx 36rpx;
  color: var(--gray-700);
  background: #fff;
  text-align: center;
}

.plain-btn:active {
  background: var(--gray-100);
}

/* 隐藏滚动条 */
.hide-scroll::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}
